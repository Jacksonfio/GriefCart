# GriefCart Environment Configuration
# Copy to .env and fill in values from the active AWS deployment outputs.

# ─── Frontend ───────────────────────────────────────────────────────────────
VITE_API_BASE=/api
# VITE_API_BASE=https://xxxxxxxxxx.execute-api.us-east-1.amazonaws.com/v1
VITE_PROXY_TARGET=https://xxxxxxxxxx.execute-api.us-east-1.amazonaws.com
VITE_COGNITO_DOMAIN=https://griefcart-dev.auth.us-east-1.amazoncognito.com
VITE_COGNITO_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx
VITE_REDIRECT_URI=http://localhost:5173

# ─── AWS Core ───────────────────────────────────────────────────────────────
AWS_REGION=us-east-1
JWT_SECRET=replace-me
COGNITO_USER_POOL_ID=us-east-1_xxxxxxxxx
COGNITO_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx
S3_DOCUMENT_BUCKET=griefcart-dev-documents
KMS_KEY_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
STEP_FUNCTION_ARN=arn:aws:states:us-east-1:123456789012:stateMachine:griefcart-dev-emergency
SES_FROM_ADDRESS=jacksonjp646@gmail.com

# ─── AI Provider Configuration ──────────────────────────────────────────────
# Choose your AI provider: bedrock (default/recommended), huggingface, or gemini
LLM_PROVIDER=bedrock

# AWS Bedrock — Open-Source Models (Meta Llama 3 / Mistral)
# Models must be enabled in your AWS Bedrock console:
# https://console.aws.amazon.com/bedrock/home#/modelaccess
# Available open-source model IDs:
#   meta.llama3-70b-instruct-v1:0   (recommended, high quality)
#   meta.llama3-8b-instruct-v1:0    (faster, lower cost)
#   mistral.mistral-7b-instruct-v0:2
#   mistral.mixtral-8x7b-instruct-v0:1
BEDROCK_MODEL_ID=meta.llama3-70b-instruct-v1:0

# HuggingFace Inference API (fallback or primary when LLM_PROVIDER=huggingface)
# Get your token at: https://huggingface.co/settings/tokens
# Store it in AWS Secrets Manager and put the ARN here
HF_API_KEY_SECRET=arn:aws:secretsmanager:us-east-1:123456789012:secret:griefcart/dev/hf-api-key-xxxxxx
HF_MODEL_ID=meta-llama/Llama-3.1-8B-Instruct

# Google Gemini (legacy fallback — still works if you have a key)
GEMINI_API_KEY=replace-me-with-your-gemini-key
